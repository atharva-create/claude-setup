{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "Agent(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "TodoWrite(*)",
      "NotebookEdit(*)",
      "AskUserQuestion(*)",
      "CronCreate(*)",
      "CronDelete(*)",
      "CronList(*)",
      "EnterPlanMode(*)",
      "ExitPlanMode(*)",
      "EnterWorktree(*)",
      "ExitWorktree(*)",
      "TaskOutput(*)",
      "TaskStop(*)",
      "RemoteTrigger(*)",
      "Skill(*)",
      "mcp__*"
    ],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/bootstrap-superpowers.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/verify-check.sh",
            "timeout": 10,
            "statusMessage": "Checking if changes were verified in browser..."
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "superpowers-dev": {
      "source": { "source": "directory", "path": "./plugins/superpowers" }
    }
  },
  "enabledPlugins": {
    "superpowers@superpowers-dev": true
  }
}
